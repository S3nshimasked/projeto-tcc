        train_resume = train.animate.shift(RIGHT * 14)
        cloud1_resume = cloud1.animate.shift(RIGHT * 14)
        cloud2_resume = cloud2.animate.shift(RIGHT * 14)

        self.play(
            train_resume,
            cloud1_resume,
            cloud2_resume,
            run_time=14,
            rate_func=linear
        )

        # Pausa final
        self.wait
